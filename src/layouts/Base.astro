---
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const defaultDescription =
  "Le même ordinateur, construit dans tous les univers : Minecraft, Factorio, jeu de la vie… Un catalogue libre pour comprendre comment on passe des portes logiques à un ordinateur.";
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? defaultDescription} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="brand">computelearning</a>
        <div class="nav-links">
          <a href="/concepts/">Concepts</a>
          <a href="/medias/">Médias</a>
          <a href="/contribuer/">Contribuer</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        Contenu sous <a href="https://creativecommons.org/licenses/by-sa/4.0/deed.fr">CC BY-SA 4.0</a>,
        code sous licence MIT. Les ressources liées appartiennent à leurs auteurs.
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #fdfcf9;
    --bg-soft: #f2efe8;
    --text: #26221c;
    --text-soft: #6b6459;
    --accent: #b3502c;
    --border: #ddd6c9;
    --cell-filled: #e8dfd0;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #191714;
      --bg-soft: #221f1b;
      --text: #ece7dd;
      --text-soft: #a39a8b;
      --accent: #e0784f;
      --border: #3a352d;
      --cell-filled: #322c23;
    }
  }

  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    line-height: 1.65;
    background: var(--bg);
    color: var(--text);
  }
  main {
    max-width: 62rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }
  h1,
  h2,
  h3 {
    line-height: 1.25;
  }
  a {
    color: var(--accent);
  }

  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg-soft);
  }
  nav {
    max-width: 62rem;
    margin: 0 auto;
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  nav a {
    text-decoration: none;
  }
  nav a:hover {
    text-decoration: underline;
  }
  .brand {
    font-weight: 700;
    color: var(--text);
  }
  .nav-links {
    display: flex;
    gap: 1.25rem;
  }

  footer {
    border-top: 1px solid var(--border);
    color: var(--text-soft);
    font-size: 0.85rem;
  }
  footer p {
    max-width: 62rem;
    margin: 0 auto;
    padding: 1rem 1.25rem;
  }

  .badge {
    display: inline-block;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.1rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-soft);
    white-space: nowrap;
  }

  .primitive {
    background: var(--bg-soft);
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1rem;
    margin: 1.25rem 0;
  }
  .primitive strong {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-soft);
    margin-bottom: 0.25rem;
  }

  .resource-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 1.5rem;
  }
  .resource-list li {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
  }
  .resource-meta {
    color: var(--text-soft);
    font-size: 0.85rem;
  }

  .matrix-wrapper {
    overflow-x: auto;
  }
  table.matrix {
    border-collapse: collapse;
    width: 100%;
    font-size: 0.9rem;
  }
  table.matrix th,
  table.matrix td {
    border: 1px solid var(--border);
    padding: 0.45rem 0.6rem;
    text-align: center;
  }
  table.matrix th {
    background: var(--bg-soft);
  }
  table.matrix th a {
    text-decoration: none;
  }
  table.matrix th.row-head {
    text-align: left;
    font-weight: 500;
  }
  table.matrix td.filled {
    background: var(--cell-filled);
    font-weight: 600;
  }
  table.matrix td.filled a {
    display: block;
    text-decoration: none;
    color: var(--text);
  }
  table.matrix td.empty {
    color: var(--text-soft);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1rem;
    padding: 0;
    list-style: none;
  }
  .card {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    background: var(--bg-soft);
  }
  .card h3 {
    margin: 0 0 0.35rem;
  }
  .card p {
    margin: 0.35rem 0 0;
    font-size: 0.9rem;
    color: var(--text-soft);
  }
</style>
